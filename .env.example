# MongoDB Connection (Optional - for CMS features)
# Get your connection string from https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# OpenAI API Key (Optional - for AI chatbot features)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub Personal Access Token (Optional - for GitHub contributions)
# Create token at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here
